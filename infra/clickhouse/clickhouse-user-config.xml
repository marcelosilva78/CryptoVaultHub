<clickhouse>
    <users>
        <default>
            <password>CHANGE_ME_CLICKHOUSE_PASSWORD</password>
            <networks>
                <ip>10.0.0.0/8</ip>
                <ip>172.16.0.0/12</ip>
                <ip>192.168.0.0/16</ip>
            </networks>
            <profile>default</profile>
            <quota>default</quota>
            <access_management>1</access_management>
            <named_collection_control>1</named_collection_control>
        </default>
    </users>
    <profiles>
        <default>
            <!-- Disable new query analyzer introduced in 24.x — infi/clickhouse_orm
                 distributed table queries crash ClickHouse with the new analyzer -->
            <allow_experimental_analyzer>0</allow_experimental_analyzer>
        </default>
    </profiles>
</clickhouse>
