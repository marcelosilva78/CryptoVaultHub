<clickhouse>
    <!--
        Single-node ClickHouse configuration for PostHog.
        Uses built-in ClickHouse Keeper so ReplicatedMergeTree tables work
        without a separate ZooKeeper service.
    -->

    <!-- Built-in Keeper for coordination (replaces ZooKeeper) -->
    <keeper_server>
        <tcp_port>9181</tcp_port>
        <server_id>1</server_id>
        <log_storage_path>/var/lib/clickhouse/coordination/log</log_storage_path>
        <snapshot_storage_path>/var/lib/clickhouse/coordination/snapshots</snapshot_storage_path>
        <coordination_settings>
            <operation_timeout_ms>10000</operation_timeout_ms>
            <session_timeout_ms>30000</session_timeout_ms>
            <raft_logs_level>warning</raft_logs_level>
        </coordination_settings>
        <raft_configuration>
            <server>
                <id>1</id>
                <hostname>clickhouse</hostname>
                <port>9234</port>
            </server>
        </raft_configuration>
    </keeper_server>

    <!-- Point ZooKeeper client to local Keeper -->
    <zookeeper>
        <node>
            <host>clickhouse</host>
            <port>9181</port>
        </node>
    </zookeeper>

    <!-- Cluster definition required by PostHog migrate_clickhouse -->
    <remote_servers>
        <posthog_migrations>
            <shard>
                <replica>
                    <host>clickhouse</host>
                    <port>9000</port>
                </replica>
            </shard>
        </posthog_migrations>
    </remote_servers>

    <!-- Macros for ReplicatedMergeTree path interpolation -->
    <macros>
        <shard>01</shard>
        <replica>clickhouse-01</replica>
        <cluster>posthog_migrations</cluster>
    </macros>

    <!-- Reduce log noise -->
    <logger>
        <level>warning</level>
        <console>1</console>
    </logger>
</clickhouse>
