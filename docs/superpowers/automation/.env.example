# CryptoVaultHub Homologation — environment variables
# Copy to .env and fill in.

# === Required ===
CVH_EMAIL=wallet@grupogreen.org
CVH_PASSWORD=
CVH_PROJECT_NAME=BrPay
CVH_CHAIN_ID=56

# === URLs (production defaults) ===
CVH_PORTAL_URL=https://portal.vaulthub.live
CVH_API_BASE_URL=https://api.vaulthub.live/client/v1

# === Optional — webhook receiver ===
# Cole a URL única do webhook.site aqui antes de rodar.
# Se ficar em branco, a suite cria UMA URL via webhook.site/token API automaticamente.
CVH_WEBHOOK_URL=

# === Optional — API key ===
# Se preenchida, a suite usa essa key. Caso contrário, faz login UI e gera uma
# nova key automaticamente via Playwright (mais lento na primeira execução).
CVH_API_KEY=

# === Optional — runtime tweaks ===
# Headless browser (true = não abre janela visual)
CVH_HEADLESS=false
# Timeout para polling de depósito (segundos)
CVH_DEPOSIT_TIMEOUT_SEC=300
# Timeout para polling de sweep automático (segundos)
CVH_SWEEP_TIMEOUT_SEC=420
# Timeout para polling de withdrawal (segundos)
CVH_WITHDRAWAL_TIMEOUT_SEC=300
# Slow-mo para ver as ações no UI (ms entre ações)
CVH_SLOWMO_MS=0
