generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-client"
}

datasource db {
  provider = "mysql"
  url      = env("ADMIN_DATABASE_URL")
}

model Client {
  id          BigInt        @id @default(autoincrement())
  name        String        @db.VarChar(200)
  slug        String        @unique @db.VarChar(100)
  status      ClientStatus  @default(active)
  tierId      BigInt?       @map("tier_id")
  custodyMode CustodyMode   @default(full_custody) @map("custody_mode")
  kytEnabled  Boolean       @default(false) @map("kyt_enabled")
  kytLevel    KytLevel      @default(basic) @map("kyt_level")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  tier      Tier?               @relation(fields: [tierId], references: [id])
  overrides ClientTierOverride[]
  projects  Project[]

  @@index([tierId], name: "idx_tier")
  @@index([slug], name: "idx_slug")
  @@map("clients")
}

model Project {
  id          BigInt        @id @default(autoincrement())
  clientId    BigInt        @map("client_id")
  name        String        @db.VarChar(200)
  slug        String        @db.VarChar(100)
  description String?       @db.VarChar(500)
  isDefault   Boolean       @default(false) @map("is_default")
  status      ProjectStatus @default(active)
  settings    Json?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, slug], name: "uq_client_slug")
  @@index([clientId, status], name: "idx_client_status")
  @@index([clientId, isDefault], name: "idx_client_default")
  @@map("projects")
}

enum ProjectStatus {
  active
  archived
  suspended
}

model Tier {
  id                    BigInt   @id @default(autoincrement())
  name                  String   @db.VarChar(100)
  baseTierId            BigInt?  @map("base_tier_id")
  isPreset              Boolean  @default(true) @map("is_preset")
  isCustom              Boolean  @default(false) @map("is_custom")
  globalRateLimit       Int      @default(100) @map("global_rate_limit")
  endpointRateLimits    Json?    @map("endpoint_rate_limits")
  maxForwardersPerChain Int      @default(100) @map("max_forwarders_per_chain")
  maxChains             Int      @default(5) @map("max_chains")
  maxWebhooks           Int      @default(10) @map("max_webhooks")
  dailyWithdrawalLimitUsd Decimal @default(10000) @map("daily_withdrawal_limit_usd") @db.Decimal(15,2)
  monitoringMode        String   @default("basic") @map("monitoring_mode") @db.VarChar(50)
  kytLevel              KytLevel @default(basic) @map("kyt_level")
  createdAt             DateTime @default(now()) @map("created_at")

  baseTier Tier?    @relation("TierHierarchy", fields: [baseTierId], references: [id])
  children Tier[]   @relation("TierHierarchy")
  clients  Client[]

  @@index([baseTierId], name: "idx_base_tier")
  @@map("tiers")
}

model ClientTierOverride {
  id            BigInt       @id @default(autoincrement())
  clientId      BigInt       @map("client_id")
  overrideKey   String       @map("override_key") @db.VarChar(100)
  overrideValue String       @map("override_value") @db.VarChar(500)
  overrideType  OverrideType @default(string) @map("override_type")

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId], name: "idx_client")
  @@map("client_tier_overrides")
}

model AuditLog {
  id          BigInt   @id @default(autoincrement())
  adminUserId String   @map("admin_user_id") @db.VarChar(64)
  action      String   @db.VarChar(100)
  entityType  String   @map("entity_type") @db.VarChar(50)
  entityId    String   @map("entity_id") @db.VarChar(64)
  details     Json?
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([adminUserId], name: "idx_admin_user")
  @@index([entityType, entityId], name: "idx_entity")
  @@index([createdAt], name: "idx_created")
  @@map("audit_logs")
}

model ClientToken {
  id          Int      @id @default(autoincrement())
  clientId    Int      @map("client_id")
  tokenId     Int      @map("token_id")
  isEnabled   Boolean  @default(true) @map("is_enabled")
  customLabel String?  @map("custom_label") @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at")
  @@unique([clientId, tokenId], name: "uq_client_token")
  @@map("client_tokens")
}

model ClientChainConfig {
  id                     Int      @id @default(autoincrement())
  clientId               Int      @map("client_id")
  chainId                Int      @map("chain_id")
  isEnabled              Boolean  @default(true) @map("is_enabled")
  customRpcHttp          String?  @map("custom_rpc_http") @db.VarChar(500)
  customRpcWs            String?  @map("custom_rpc_ws") @db.VarChar(500)
  confirmationsOverride  Int?     @map("confirmations_override")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")
  @@unique([clientId, chainId], name: "uq_client_chain")
  @@map("client_chain_config")
}

enum ClientStatus {
  active
  suspended
  onboarding
}

enum CustodyMode {
  full_custody
  co_sign
  client_initiated
}

enum KytLevel {
  basic
  enhanced
  full
}

enum OverrideType {
  string
  number
  boolean
  json
}

// ---------------------------------------------------------------------------
// RPC Providers — external RPC service vendors (Alchemy, Infura, etc.)
// ---------------------------------------------------------------------------

model RpcProvider {
  id               BigInt   @id @default(autoincrement())
  name             String   @db.VarChar(100)
  slug             String   @unique @db.VarChar(50)
  website          String?  @db.VarChar(255)
  authMethod       RpcAuthMethod @default(api_key) @map("auth_method")
  authHeaderName   String?  @default("x-api-key") @map("auth_header_name") @db.VarChar(100)
  apiKeyEncrypted  String?  @map("api_key_encrypted") @db.Text
  apiSecretEncrypted String? @map("api_secret_encrypted") @db.Text
  notes            String?  @db.Text
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  nodes RpcNode[]

  @@map("rpc_providers")
}

// ---------------------------------------------------------------------------
// RPC Nodes — individual RPC endpoints per chain per provider
// ---------------------------------------------------------------------------

model RpcNode {
  id                    BigInt      @id @default(autoincrement())
  providerId            BigInt      @map("provider_id")
  chainId               Int         @map("chain_id")
  endpointUrl           String      @map("endpoint_url") @db.VarChar(512)
  wsEndpointUrl         String?     @map("ws_endpoint_url") @db.VarChar(512)
  priority              Int         @default(50)
  weight                Int         @default(100)
  status                RpcNodeStatus @default(standby)
  maxRequestsPerSecond  Int?        @default(50) @map("max_requests_per_second")
  maxRequestsPerMinute  Int?        @default(2000) @map("max_requests_per_minute")
  timeoutMs             Int         @default(15000) @map("timeout_ms")
  healthCheckIntervalS  Int         @default(30) @map("health_check_interval_s")
  lastHealthCheckAt     DateTime?   @map("last_health_check_at")
  lastHealthyAt         DateTime?   @map("last_healthy_at")
  consecutiveFailures   Int         @default(0) @map("consecutive_failures")
  healthScore           Decimal     @default(100.00) @map("health_score") @db.Decimal(5, 2)
  tags                  Json?
  isActive              Boolean     @default(true) @map("is_active")
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

  provider     RpcProvider       @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([chainId, status, priority], name: "idx_chain_status")
  @@index([providerId], name: "idx_provider")
  @@map("rpc_nodes")
}

// ---------------------------------------------------------------------------
// Provider Switch Log — audit trail for provider switchovers
// ---------------------------------------------------------------------------

model ProviderSwitchLog {
  id                  BigInt          @id @default(autoincrement())
  chainId             Int             @map("chain_id")
  fromNodeId          BigInt?         @map("from_node_id")
  toNodeId            BigInt          @map("to_node_id")
  reason              SwitchReason
  initiatedBy         String          @default("system") @map("initiated_by") @db.VarChar(100)
  status              SwitchStatus    @default(initiated)
  pendingJobsAtSwitch Int?            @map("pending_jobs_at_switch")
  notes               String?         @db.Text
  createdAt           DateTime        @default(now()) @map("created_at")

  @@index([chainId, createdAt(sort: Desc)], name: "idx_chain_time")
  @@map("provider_switch_log")
}

enum RpcAuthMethod {
  api_key
  bearer
  header
  none
}

enum RpcNodeStatus {
  active
  draining
  standby
  unhealthy
  disabled
}

enum SwitchReason {
  manual
  failover
  health_degraded
  rate_limited
  draining
}

enum SwitchStatus {
  initiated
  draining
  completed
  rolled_back
}
