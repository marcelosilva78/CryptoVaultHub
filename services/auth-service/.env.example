# Auth Service Configuration
PORT=3003
DATABASE_URL=mysql://root:password@localhost:3306/cvh_auth

# JWT Configuration
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET_64_CHARS_MIN
JWT_EXPIRES_IN_SECONDS=900

# Refresh token TTL
REFRESH_TOKEN_TTL_DAYS=7

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Encryption key for TOTP secrets at rest (use a strong random key, 32+ chars)
TOTP_ENCRYPTION_KEY=change-me-to-strong-random-key
