# Notification Service Configuration
PORT=3007
DATABASE_URL=mysql://root:password@localhost:3306/cvh_notifications

# Redis (for BullMQ and event streams)
REDIS_HOST=localhost
REDIS_PORT=6379

# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASS=CHANGE_ME
SMTP_FROM=CryptoVaultHub <notifications@example.com>

# Shared secret for authenticating internal service-to-service calls
INTERNAL_SERVICE_KEY=change-me-to-random-secret
