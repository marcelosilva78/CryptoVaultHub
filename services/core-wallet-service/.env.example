# Core Wallet Service Configuration
PORT=3004
DATABASE_URL=mysql://root:password@localhost:3306/cvh_wallets

# Redis (for nonce management, caching, BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Key Vault Service (internal network)
KEY_VAULT_URL=http://localhost:3005

# mTLS for Key Vault communication (set to true in production)
# When enabled, core-wallet-service presents a client certificate to key-vault-service
VAULT_TLS_ENABLED=false
VAULT_CLIENT_CERT_PATH=/tls/client.crt
VAULT_CLIENT_KEY_PATH=/tls/client.key
VAULT_TLS_CA_PATH=/tls/ca.crt

# Tatum API Key (for RPC access)
TATUM_API_KEY=CHANGE_ME

# Whitelist cooldown period in hours
WHITELIST_COOLDOWN_HOURS=24

# Shared secret for authenticating internal service-to-service calls
INTERNAL_SERVICE_KEY=change-me-to-random-secret
