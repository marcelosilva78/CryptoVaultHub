// NOTE: This service uses cross-database queries (cvh_admin, cvh_wallets, cvh_compliance).
// This is a known Prisma limitation with MySQL — Prisma does not natively support
// multi-database schemas. The MySQL user must have access to all referenced databases,
// and DATABASE_URL should point to the primary database (cvh_wallets).

generator client {
  provider = "prisma-client-js"
  output        = "../src/generated/prisma-client"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Client management (cvh_admin)
// ---------------------------------------------------------------------------

model Client {
  id          BigInt   @id @default(autoincrement())
  name        String   @db.VarChar(200)
  slug        String   @unique @db.VarChar(100)
  status      String   @default("active") @db.VarChar(20)
  tierId      BigInt   @map("tier_id")
  custodyMode String   @default("full_custody") @db.VarChar(30) @map("custody_mode")
  kytEnabled  Boolean  @default(false) @map("kyt_enabled")
  kytLevel    String   @default("basic") @db.VarChar(10) @map("kyt_level")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("clients")
}

// ---------------------------------------------------------------------------
// Chains and Tokens (cvh_wallets)
// ---------------------------------------------------------------------------

model Chain {
  id                      Int     @id @map("chain_id")
  name                    String  @db.VarChar(50)
  shortName               String  @db.VarChar(10) @map("short_name")
  nativeCurrencySymbol    String  @db.VarChar(10) @map("native_currency_symbol")
  nativeCurrencyDecimals  Int     @default(18) @map("native_currency_decimals")
  rpcEndpoints            Json    @map("rpc_endpoints")
  blockTimeSeconds        Decimal @db.Decimal(5, 2) @map("block_time_seconds")
  confirmationsDefault    Int       @map("confirmations_default")
  finalityThreshold       Int       @default(32) @map("finality_threshold")
  walletFactoryAddress    String?   @db.VarChar(42) @map("wallet_factory_address")
  forwarderFactoryAddress String? @db.VarChar(42) @map("forwarder_factory_address")
  walletImplAddress       String? @db.VarChar(42) @map("wallet_impl_address")
  forwarderImplAddress    String? @db.VarChar(42) @map("forwarder_impl_address")
  multicall3Address       String  @default("0xcA11bde05977b3631167028862bE2a173976CA11") @db.VarChar(42) @map("multicall3_address")
  explorerUrl             String? @db.VarChar(200) @map("explorer_url")
  gasPriceStrategy        String    @default("eip1559") @db.VarChar(10) @map("gas_price_strategy")
  status                  String    @default("active") @db.VarChar(20)
  statusReason            String?   @db.VarChar(255) @map("status_reason")
  statusChangedAt         DateTime? @map("status_changed_at")
  isActive                Boolean   @default(true) @map("is_active")
  isTestnet               Boolean   @default(false) @map("is_testnet")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  @@index([status], name: "idx_status")
  @@map("chains")
}

model Token {
  id              BigInt   @id @default(autoincrement())
  chainId         Int      @map("chain_id")
  contractAddress String   @db.VarChar(42) @map("contract_address")
  symbol          String   @db.VarChar(20)
  name            String   @db.VarChar(100)
  decimals        Int      @db.TinyInt
  isNative        Boolean  @default(false) @map("is_native")
  isDefault       Boolean  @default(true) @map("is_default")
  isActive        Boolean  @default(true) @map("is_active")
  coingeckoId     String?  @db.VarChar(100) @map("coingecko_id")
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([chainId, contractAddress], name: "uq_chain_contract")
  @@map("tokens")
}

// ---------------------------------------------------------------------------
// Wallets and Deposit Addresses
// ---------------------------------------------------------------------------

model Wallet {
  id         BigInt   @id @default(autoincrement())
  clientId   BigInt   @map("client_id")
  projectId  BigInt   @map("project_id")
  chainId    Int      @map("chain_id")
  address    String   @db.VarChar(42)
  walletType String   @db.VarChar(20) @map("wallet_type")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([clientId, chainId, walletType], name: "uq_client_chain_type")
  @@index([clientId, projectId])
  @@map("wallets")
}

model DepositAddress {
  id              BigInt   @id @default(autoincrement())
  clientId        BigInt   @map("client_id")
  projectId       BigInt   @map("project_id")
  chainId         Int      @map("chain_id")
  walletId        BigInt   @map("wallet_id")
  address         String   @db.VarChar(42)
  externalId      String   @db.VarChar(200) @map("external_id")
  label           String?  @db.VarChar(200)
  salt            String   @db.VarChar(66)
  isDeployed      Boolean  @default(false) @map("is_deployed")
  addressGroupId  BigInt?  @map("address_group_id")
  deployTraceId   BigInt?  @map("deploy_trace_id")
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([clientId, chainId, externalId], name: "uq_client_chain_external")
  @@index([address])
  @@index([addressGroupId], map: "idx_address_group")
  @@index([clientId, projectId])
  @@map("deposit_addresses")
}

model WhitelistedAddress {
  id             BigInt    @id @default(autoincrement())
  clientId       BigInt    @map("client_id")
  address        String    @db.VarChar(42)
  label          String    @db.VarChar(200)
  chainId        Int       @map("chain_id")
  status         String    @default("cooldown") @db.VarChar(20)
  cooldownEndsAt DateTime? @map("cooldown_ends_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@map("whitelisted_addresses")
}

// ---------------------------------------------------------------------------
// Transactions
// ---------------------------------------------------------------------------

model Deposit {
  id                    BigInt    @id @default(autoincrement())
  clientId              BigInt    @map("client_id")
  projectId             BigInt    @map("project_id")
  chainId               Int       @map("chain_id")
  forwarderAddress      String    @db.VarChar(42) @map("forwarder_address")
  externalId            String    @db.VarChar(200) @map("external_id")
  tokenId               BigInt    @map("token_id")
  amount                String    @db.VarChar(78)
  amountRaw             String    @db.VarChar(78) @map("amount_raw")
  txHash                String    @db.VarChar(66) @map("tx_hash")
  blockNumber           BigInt    @map("block_number")
  fromAddress           String    @db.VarChar(42) @map("from_address")
  status                String    @default("pending") @db.VarChar(20)
  confirmations         Int       @default(0)
  confirmationsRequired Int       @map("confirmations_required")
  sweepTxHash           String?   @db.VarChar(66) @map("sweep_tx_hash")
  kytResult             String?   @db.VarChar(20) @map("kyt_result")
  detectedAt            DateTime  @default(now()) @map("detected_at")
  confirmedAt           DateTime? @map("confirmed_at")
  sweptAt               DateTime? @map("swept_at")

  @@unique([txHash, forwarderAddress], name: "uq_tx_forwarder")
  @@index([clientId, status])
  @@index([clientId, projectId])
  @@map("deposits")
}

model Withdrawal {
  id             BigInt    @id @default(autoincrement())
  clientId       BigInt    @map("client_id")
  projectId      BigInt    @map("project_id")
  chainId        Int       @map("chain_id")
  tokenId        BigInt    @map("token_id")
  fromWallet     String    @db.VarChar(42) @map("from_wallet")
  toAddressId    BigInt    @map("to_address_id")
  toAddress      String    @db.VarChar(42) @map("to_address")
  toLabel        String    @db.VarChar(200) @map("to_label")
  amount         String    @db.VarChar(78)
  amountRaw      String    @db.VarChar(78) @map("amount_raw")
  txHash         String?   @db.VarChar(66) @map("tx_hash")
  status         String    @default("pending_approval") @db.VarChar(30)
  sequenceId     Int?      @map("sequence_id")
  gasCost        String?   @db.VarChar(78) @map("gas_cost")
  kytResult      String?   @db.VarChar(20) @map("kyt_result")
  idempotencyKey String    @unique @db.VarChar(200) @map("idempotency_key")
  createdAt      DateTime  @default(now()) @map("created_at")
  submittedAt    DateTime? @map("submitted_at")
  confirmedAt    DateTime? @map("confirmed_at")

  @@index([clientId, status])
  @@index([clientId, projectId])
  @@map("withdrawals")
}

// ---------------------------------------------------------------------------
// Flush Operations (cvh_transactions)
// ---------------------------------------------------------------------------

model FlushOperation {
  id              BigInt    @id @default(autoincrement())
  operationUid    String    @unique @db.VarChar(255) @map("operation_uid")
  clientId        BigInt    @map("client_id")
  projectId       BigInt    @map("project_id")
  chainId         Int       @map("chain_id")
  operationType   String    @db.VarChar(20) @map("operation_type")
  mode            String    @default("manual") @db.VarChar(20)
  triggerType     String    @db.VarChar(20) @map("trigger_type")
  triggeredBy     BigInt?   @map("triggered_by")
  isDryRun        Boolean   @default(false) @map("is_dry_run")
  status          String    @default("pending") @db.VarChar(30)
  tokenId         BigInt?   @map("token_id")
  walletId        BigInt    @map("wallet_id")
  totalAddresses  Int       @default(0) @map("total_addresses")
  succeededCount  Int       @default(0) @map("succeeded_count")
  failedCount     Int       @default(0) @map("failed_count")
  totalAmount     Decimal   @default(0) @db.Decimal(65, 0) @map("total_amount")
  succeededAmount Decimal   @default(0) @db.Decimal(65, 0) @map("succeeded_amount")
  gasCostTotal    Decimal   @default(0) @db.Decimal(65, 0) @map("gas_cost_total")
  txHash          String?   @db.VarChar(66) @map("tx_hash")
  batchTxHashes   Json?     @map("batch_tx_hashes")
  errorMessage    String?   @db.Text @map("error_message")
  dryRunResult    Json?     @map("dry_run_result")
  filtersApplied  Json?     @map("filters_applied")
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  items           FlushItem[]

  @@index([clientId, projectId, status, createdAt], map: "idx_client_project")
  @@index([chainId, operationType, status], map: "idx_chain_type")
  @@map("flush_operations")
}

model FlushItem {
  id               BigInt    @id @default(autoincrement())
  operationId      BigInt    @map("operation_id")
  depositAddressId BigInt    @map("deposit_address_id")
  address          String    @db.VarChar(42)
  status           String    @default("pending") @db.VarChar(20)
  tokenId          BigInt?   @map("token_id")
  amountBefore     Decimal?  @db.Decimal(65, 0) @map("amount_before")
  amountFlushed    Decimal?  @db.Decimal(65, 0) @map("amount_flushed")
  txHash           String?   @db.VarChar(66) @map("tx_hash")
  gasCost          Decimal?  @db.Decimal(65, 0) @map("gas_cost")
  errorMessage     String?   @db.Text @map("error_message")
  processedAt      DateTime? @map("processed_at")

  operation        FlushOperation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  @@index([operationId, status], map: "idx_operation")
  @@index([depositAddressId], map: "idx_address")
  @@map("flush_items")
}

// ---------------------------------------------------------------------------
// Deploy Traces (cvh_transactions)
// ---------------------------------------------------------------------------

model DeployTrace {
  id              BigInt   @id @default(autoincrement())
  clientId        BigInt   @map("client_id")
  projectId       BigInt   @map("project_id")
  chainId         Int      @map("chain_id")
  resourceType    String   @db.VarChar(30) @map("resource_type")
  resourceId      BigInt   @map("resource_id")
  address         String   @db.VarChar(42)
  txHash          String   @db.VarChar(66) @map("tx_hash")
  blockNumber     BigInt   @map("block_number")
  blockHash       String?  @db.VarChar(66) @map("block_hash")
  blockTimestamp  BigInt?  @map("block_timestamp")
  deployerAddress String?  @db.VarChar(42) @map("deployer_address")
  factoryAddress  String?  @db.VarChar(42) @map("factory_address")
  salt            String?  @db.VarChar(66)
  initCodeHash    String?  @db.VarChar(66) @map("init_code_hash")
  gasUsed         BigInt?  @map("gas_used")
  gasPrice        BigInt?  @map("gas_price")
  gasCostWei      Decimal? @db.Decimal(65, 0) @map("gas_cost_wei")
  rpcProviderId   BigInt?  @map("rpc_provider_id")
  rpcNodeId       BigInt?  @map("rpc_node_id")
  explorerUrl     String   @db.VarChar(512) @map("explorer_url")
  correlationId   String?  @db.VarChar(255) @map("correlation_id")
  triggeredBy     BigInt?  @map("triggered_by")
  triggerType     String   @default("system") @db.VarChar(20) @map("trigger_type")
  eventLogs       Json?    @map("event_logs")
  metadata        Json?
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([clientId, projectId, resourceType], map: "idx_client_project_resource")
  @@index([chainId, txHash], map: "idx_chain_tx")
  @@index([address], map: "idx_deploy_address")
  @@index([correlationId], map: "idx_correlation")
  @@map("deploy_traces")
}

// ---------------------------------------------------------------------------
// Address Groups (cvh_wallets)
// ---------------------------------------------------------------------------

model AddressGroup {
  id              BigInt   @id @default(autoincrement())
  groupUid        String   @unique @db.VarChar(255) @map("group_uid")
  clientId        BigInt   @map("client_id")
  projectId       BigInt   @map("project_id")
  externalId      String?  @db.VarChar(255) @map("external_id")
  label           String?  @db.VarChar(255)
  derivationSalt  String   @db.VarChar(66) @map("derivation_salt")
  computedAddress String   @db.VarChar(42) @map("computed_address")
  status          String   @default("active") @db.VarChar(20)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([clientId, derivationSalt], name: "uq_client_salt")
  @@index([clientId, projectId], map: "idx_group_client_project")
  @@index([computedAddress], map: "idx_group_address")
  @@map("address_groups")
}

// ---------------------------------------------------------------------------
// Project-Isolated Contract Deployment
// ---------------------------------------------------------------------------

model ProjectChain {
  id                        BigInt   @id @default(autoincrement())
  projectId                 BigInt   @map("project_id")
  chainId                   Int      @map("chain_id")
  walletFactoryAddress      String?  @db.VarChar(42) @map("wallet_factory_address")
  forwarderFactoryAddress   String?  @db.VarChar(42) @map("forwarder_factory_address")
  walletImplAddress         String?  @db.VarChar(42) @map("wallet_impl_address")
  forwarderImplAddress      String?  @db.VarChar(42) @map("forwarder_impl_address")
  hotWalletAddress          String?  @db.VarChar(42) @map("hot_wallet_address")
  hotWalletSequenceId       Int      @default(0) @map("hot_wallet_sequence_id")
  deployStatus              String   @default("pending") @db.VarChar(20) @map("deploy_status")
  deployStartedAt           DateTime? @map("deploy_started_at")
  deployCompletedAt         DateTime? @map("deploy_completed_at")
  deployError               String?  @db.Text @map("deploy_error")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")
  traces                    ProjectDeployTrace[]

  @@unique([projectId, chainId], name: "uq_project_chain")
  @@map("project_chains")
}

model ProjectDeployTrace {
  id                    BigInt   @id @default(autoincrement())
  projectId             BigInt   @map("project_id")
  chainId               Int      @map("chain_id")
  projectChainId        BigInt   @map("project_chain_id")
  contractType          String   @db.VarChar(30) @map("contract_type")
  contractAddress       String?  @db.VarChar(42) @map("contract_address")
  txHash                String?  @db.VarChar(66) @map("tx_hash")
  blockNumber           BigInt?  @map("block_number")
  blockHash             String?  @db.VarChar(66) @map("block_hash")
  gasUsed               String?  @db.VarChar(78) @map("gas_used")
  gasPrice              String?  @db.VarChar(78) @map("gas_price")
  gasCostWei            String?  @db.VarChar(78) @map("gas_cost_wei")
  deployerAddress       String   @db.VarChar(42) @map("deployer_address")
  calldataHex           String?  @db.MediumText @map("calldata_hex")
  constructorArgsJson   Json?    @map("constructor_args_json")
  signedTxHex           String?  @db.MediumText @map("signed_tx_hex")
  rpcRequestJson        Json?    @map("rpc_request_json")
  rpcResponseJson       Json?    @map("rpc_response_json")
  abiJson               Json?    @map("abi_json")
  bytecodeHash          String?  @db.VarChar(66) @map("bytecode_hash")
  verificationProofJson Json?    @map("verification_proof_json")
  explorerUrl           String?  @db.VarChar(500) @map("explorer_url")
  status                String   @default("pending") @db.VarChar(20)
  errorMessage          String?  @db.Text @map("error_message")
  createdAt             DateTime @default(now()) @map("created_at")
  confirmedAt           DateTime? @map("confirmed_at")
  projectChain          ProjectChain @relation(fields: [projectChainId], references: [id])

  @@index([projectId, chainId])
  @@index([txHash])
  @@map("project_deploy_traces")
}

// ---------------------------------------------------------------------------
// Compliance / KYT
// ---------------------------------------------------------------------------

model SanctionsEntry {
  id           BigInt   @id @default(autoincrement())
  listSource   String   @db.VarChar(50) @map("list_source")
  address      String   @db.VarChar(100)
  addressType  String   @db.VarChar(20) @map("address_type")
  entityName   String?  @db.VarChar(500) @map("entity_name")
  entityId     String?  @db.VarChar(100) @map("entity_id")
  isActive     Boolean  @default(true) @map("is_active")
  lastSyncedAt DateTime @map("last_synced_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([listSource, address])
  @@index([address])
  @@map("sanctions_entries")
}

model ScreeningResult {
  id           BigInt   @id @default(autoincrement())
  clientId     BigInt   @map("client_id")
  address      String   @db.VarChar(42)
  direction    String   @db.VarChar(10)
  trigger      String   @db.VarChar(20)
  txHash       String?  @db.VarChar(66) @map("tx_hash")
  listsChecked Json     @map("lists_checked")
  result       String   @db.VarChar(20)
  matchDetails Json?    @map("match_details")
  action       String   @db.VarChar(20)
  screenedAt   DateTime @default(now()) @map("screened_at")

  @@index([clientId, screenedAt])
  @@index([address])
  @@map("screening_results")
}

model ComplianceAlert {
  id            BigInt    @id @default(autoincrement())
  clientId      BigInt    @map("client_id")
  severity      String    @db.VarChar(10)
  alertType     String    @db.VarChar(50) @map("alert_type")
  address       String    @db.VarChar(42)
  matchedEntity String?   @db.VarChar(500) @map("matched_entity")
  matchedList   String?   @db.VarChar(50) @map("matched_list")
  amount        String?   @db.VarChar(78)
  tokenSymbol   String?   @db.VarChar(20) @map("token_symbol")
  status        String    @default("open") @db.VarChar(20)
  resolvedAt    DateTime? @map("resolved_at")
  resolvedBy    String?   @db.VarChar(100) @map("resolved_by")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([clientId, status])
  @@map("compliance_alerts")
}
