# Chain Indexer Service Configuration
PORT=3006
DATABASE_URL=mysql://root:password@localhost:3306/cvh_indexer

# Redis (for streams, BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Polling interval in milliseconds
POLLING_INTERVAL_MS=15000

# Block confirmations (override per chain via DB)
DEFAULT_CONFIRMATIONS=12

# Tatum API Key (for RPC access)
TATUM_API_KEY=CHANGE_ME
