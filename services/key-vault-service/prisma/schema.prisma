generator client {
  provider = "prisma-client-js"
  output        = "../src/generated/prisma-client"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model MasterSeed {
  id            BigInt   @id @default(autoincrement())
  seedId        String   @unique @map("seed_id") @db.VarChar(64)
  encryptedSeed Bytes    @map("encrypted_seed") @db.Blob
  encryptedDek  Bytes    @map("encrypted_dek") @db.Blob
  iv            Bytes    @db.VarBinary(16)
  authTag       Bytes    @map("auth_tag") @db.VarBinary(16)
  salt          Bytes    @db.VarBinary(32)
  kdfIterations Int      @default(100000) @map("kdf_iterations")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("master_seeds")
}

model DerivedKey {
  id             BigInt    @id @default(autoincrement())
  clientId       BigInt    @map("client_id")
  projectId      BigInt?   @map("project_id")
  keyType        KeyType   @map("key_type")
  chainScope     String    @default("evm") @map("chain_scope") @db.VarChar(10)
  publicKey      String    @map("public_key") @db.VarChar(130)
  address        String    @db.VarChar(42)
  derivationPath String    @map("derivation_path") @db.VarChar(50)
  encryptedKey   Bytes     @map("encrypted_key") @db.Blob
  encryptedDek   Bytes     @map("encrypted_dek") @db.Blob
  iv             Bytes     @db.VarBinary(16)
  authTag        Bytes     @map("auth_tag") @db.VarBinary(16)
  salt           Bytes     @db.VarBinary(32)
  isActive       Boolean   @default(true) @map("is_active")
  lastUsedAt     DateTime? @map("last_used_at")
  signCount      BigInt    @default(0) @map("sign_count")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@unique([projectId, keyType, chainScope], name: "uq_project_keytype_chain")
  @@index([address], name: "idx_address")
  @@index([clientId, keyType], name: "idx_client_keytype")
  @@map("derived_keys")
}

model ShamirShare {
  id              BigInt    @id @default(autoincrement())
  clientId        BigInt    @map("client_id")
  projectId       BigInt?   @map("project_id")
  shareIndex      Int       @map("share_index") @db.TinyInt
  custodian       String    @db.VarChar(50)
  encryptedShare  Bytes     @map("encrypted_share") @db.Blob
  encryptedDek    Bytes     @map("encrypted_dek") @db.Blob
  iv              Bytes     @db.VarBinary(16)
  authTag         Bytes     @map("auth_tag") @db.VarBinary(16)
  salt            Bytes     @db.VarBinary(32)
  isDistributed   Boolean   @default(false) @map("is_distributed")
  distributedAt   DateTime? @map("distributed_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@unique([clientId, projectId, shareIndex], name: "uq_client_project_share")
  @@index([projectId], name: "idx_project_shares")
  @@map("shamir_shares")
}

model KeyVaultAudit {
  id          BigInt   @id @default(autoincrement())
  operation   String   @db.VarChar(50)
  clientId    BigInt?  @map("client_id")
  keyType     String?  @map("key_type") @db.VarChar(20)
  address     String?  @db.VarChar(42)
  txHash      String?  @map("tx_hash") @db.VarChar(66)
  chainId     Int?     @map("chain_id")
  requestedBy String   @map("requested_by") @db.VarChar(100)
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([clientId, operation, createdAt], name: "idx_client_op")
  @@map("key_vault_audit")
}

// M-8: The SQL DDL for project_seeds uses TEXT (not BLOB) for encrypted columns
// because EncryptionService hex-encodes all ciphertext, IV, auth tag, and salt
// values. This is intentional and differs from master_seeds which uses BLOB for
// legacy binary storage. Prisma maps Bytes to the underlying column type; the
// actual storage format is hex-encoded strings in TEXT columns.
model ProjectSeed {
  id              BigInt   @id @default(autoincrement())
  projectId       BigInt   @unique @map("project_id")
  encryptedSeed   Bytes    @map("encrypted_seed") @db.Blob
  encryptedDek    Bytes    @map("encrypted_dek") @db.Blob
  iv              Bytes    @db.VarBinary(16)
  authTag         Bytes    @map("auth_tag") @db.VarBinary(16)
  salt            Bytes    @db.VarBinary(32)
  kdfIterations   Int      @default(600000) @map("kdf_iterations")
  seedShownToClient Boolean @default(false) @map("seed_shown_to_client")
  shamirSplitDone Boolean  @default(false) @map("shamir_split_done")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("project_seeds")
}

enum KeyType {
  platform
  client
  backup
  gas_tank
}
