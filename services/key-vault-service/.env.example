# Key Vault Service Configuration
PORT=3005
DATABASE_URL=mysql://root:password@localhost:3306/cvh_keyvault

# CRITICAL: Use a strong, random password in production (64+ characters)
VAULT_MASTER_PASSWORD=CHANGE_ME_TO_A_STRONG_RANDOM_PASSWORD

# PBKDF2 iterations for KEK derivation (100000 recommended for production)
KDF_ITERATIONS=100000
