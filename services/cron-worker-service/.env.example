# Cron/Worker Service Configuration
PORT=3008
DATABASE_URL=mysql://root:password@localhost:3306/cvh_wallets

# Redis (for BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Key Vault Service (internal network)
KEY_VAULT_URL=http://localhost:3005

# Sweep interval in milliseconds
SWEEP_INTERVAL_MS=60000

# Gas tank low threshold in ETH
GAS_TANK_LOW_THRESHOLD=0.1

# OFAC SDN list URL
OFAC_SDN_URL=https://www.treasury.gov/ofac/downloads/sdn_advanced.xml

# Tatum API Key (for RPC access)
TATUM_API_KEY=CHANGE_ME
