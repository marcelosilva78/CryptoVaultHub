# Domain
BASE_DOMAIN=vaulthub.live

# Cloudflare DNS API Token (for Let's Encrypt DNS-01 challenge)
# Required for SSL certificates on private IPs / VPN environments
# Generate at: https://dash.cloudflare.com/profile/api-tokens → Edit zone DNS
CLOUDFLARE_DNS_API_TOKEN=

# MySQL
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_USER=cvh_admin
MYSQL_PASSWORD=changeme
MYSQL_ROOT_PASSWORD=changeme

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# Key Vault
VAULT_MASTER_PASSWORD=changeme-use-strong-password

# Inter-service authentication key (shared secret for internal API calls)
INTERNAL_SERVICE_KEY=changeme-use-long-random-string

# JWT / Auth
# Secret used to sign JWT access tokens
JWT_SECRET=changeme-use-long-random-string
# Access token lifetime in seconds (default: 900 = 15 min)
JWT_EXPIRES_IN_SECONDS=900
# Refresh token lifetime in days (default: 7)
REFRESH_TOKEN_TTL_DAYS=7
# AES-256 key used to encrypt TOTP secrets at rest (must be 32 bytes hex)
TOTP_ENCRYPTION_KEY=changeme-use-64-char-hex-string

# Monitoring
# Grafana admin panel password
GRAFANA_PASSWORD=changeme

# RPC Endpoints
RPC_ETH_HTTP=https://eth-mainnet.gateway.tatum.io/
RPC_ETH_WS=wss://eth-mainnet.gateway.tatum.io/ws
RPC_BSC_HTTP=https://bsc-mainnet.gateway.tatum.io/
RPC_BSC_WS=wss://bsc-mainnet.gateway.tatum.io/ws
RPC_POLYGON_HTTP=https://polygon-mainnet.gateway.tatum.io/
TATUM_API_KEY=your-tatum-api-key

# PostHog
POSTHOG_HOST=http://posthog-web:8000
POSTHOG_API_KEY=phc_your_key_here

# Kong
KONG_ADMIN_URL=http://api-gateway:8001

# RPC Gateway
RPC_GATEWAY_URL=http://rpc-gateway-service:3009

# Jobs Database
CVH_JOBS_MYSQL_HOST=mysql
CVH_JOBS_MYSQL_PORT=3306
CVH_JOBS_MYSQL_USER=cvh_jobs
CVH_JOBS_MYSQL_PASSWORD=changeme
CVH_JOBS_MYSQL_DATABASE=cvh_jobs

# Exports Database
CVH_EXPORTS_MYSQL_HOST=mysql
CVH_EXPORTS_MYSQL_PORT=3306
CVH_EXPORTS_MYSQL_USER=cvh_exports
CVH_EXPORTS_MYSQL_PASSWORD=changeme
CVH_EXPORTS_MYSQL_DATABASE=cvh_exports

# Export file storage (bind-mounted from /docker/data/exports on host)
EXPORT_STORAGE_PATH=/data/exports

# Docker storage base path (LVM volume mounted at /docker)
DOCKER_DATA_PATH=/docker/data
EXPORT_MAX_ROWS_SYNC=1000
EXPORT_FILE_EXPIRY_HOURS=24

# ─── mTLS (Key Vault) ───
VAULT_TLS_ENABLED=false
# Set to true to enable mTLS between core-wallet and key-vault
# Run scripts/generate-vault-certs.sh first

# ─── Observability ───
TRACING_ENABLED=false
JAEGER_ENDPOINT=http://jaeger:4318/v1/traces

# ─── RPC Encryption ───
# RPC_ENCRYPTION_KEY=  # Optional: dedicated key for RPC API key encryption (falls back to INTERNAL_SERVICE_KEY)
