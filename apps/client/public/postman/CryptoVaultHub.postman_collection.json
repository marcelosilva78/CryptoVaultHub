      "name": "6. Activity & reporting",
      "description": "Endpoints somente-leitura para painéis e reconciliação. Usam exclusivamente API key + scopes de leitura.",
      "item": [
        {
          "name": "Enriched forwarder listing",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('depositAddresses returned', () => pm.expect(j.depositAddresses).to.be.an('array'));",
                  "const sample = (j.depositAddresses || [])[0] || {};",
                  "['salt','parentAddress','deployerAddress','feeAddress','factoryAddress','totalDeposits','lastDepositAt'].forEach(k =>",
                  "  pm.test('field ' + k + ' present', () => pm.expect(sample).to.have.property(k))",
                  ");",
                  "console.log('total forwarders:', j.count, '— deployed:', (j.depositAddresses||[]).filter(a => a.isDeployed).length);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/deposit-addresses?limit=200",
