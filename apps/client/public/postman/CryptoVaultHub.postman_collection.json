          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Calcula uma janela [hoje-7, hoje] em UTC para o exemplo",
                  "const today = new Date();",
                  "const past = new Date(Date.now() - 7*24*60*60*1000);",
                  "pm.collectionVariables.set('rangeFrom', past.toISOString().slice(0,10));",
                  "pm.collectionVariables.set('rangeTo', today.toISOString().slice(0,10));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "console.log('deposits in window:', j.deposits?.length, ' meta.total:', j.meta?.total);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/deposits?limit=200&status=swept&chainId={{chainId}}&fromDate={{rangeFrom}}&toDate={{rangeTo}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "deposits"
              ],
              "query": [
                { "key": "limit", "value": "200" },
                { "key": "status", "value": "swept" },
                { "key": "chainId", "value": "{{chainId}}" },
                { "key": "fromDate", "value": "{{rangeFrom}}" },
                { "key": "toDate", "value": "{{rangeTo}}" }
              ]
            },
            "description": "Filtro por `status` + `chainId` + janela `fromDate`/`toDate`. Datas em `YYYY-MM-DD` são interpretadas inclusivamente em UTC — `toDate=2026-05-12` engloba todo o dia 12 até 23:59:59.999Z. Status enum (lifecycle): pending → detected → confirming → confirmed → swept (terminal) | failed. Em produção, depósitos completos quase sempre estão em `swept`, raramente em `confirmed` (o cron de sweep avança em ~30s)."
          }
        },
